# Dependencies
node_modules/

# SvelteKit / Vite build output
.svelte-kit/
build/
.vercel/
.netlify/
.output/

# Environment & secrets — never commit real keys
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs & misc
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Uploaded media (local dev artifacts)
static/uploads/*
!static/uploads/.gitkeep

# Package manager lockfile from the original template (we use npm)
bun.lock
